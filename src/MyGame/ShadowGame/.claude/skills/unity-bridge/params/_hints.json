    ]
  },
  "reflection-method-call": {
    "notes": [
      "When calling a no-args method, set parametersMatchLevel:0 (default 2 requires strict parameter matching)",
      "typeName supports fully qualified names (UnityEngine.Application), auto-split into namespace + short name"
    ]
  },
  "lightprobe-configure-lights": {
    "commonMistakes": [
      "Parameter is namePattern (string, supports * wildcards), NOT gameObjectRef (object)",
      "No intensity field; only namePattern and mode"
    ],
    "notes": [
      "mode values: Realtime, Baked, Mixed",
      "namePattern supports wildcards: 'StreetLight*', '*_Spot', '*' (matches all)",
      "Use lightprobe-analyze first to inspect current light configuration before modifying"
    ]
  },
  "gameobject-component-list-all": {
    "notes": [
      "Pass gameObjectRef to list components on an object; omit to list all available component types in the project",
      "Format when listing object components: 'TypeName (instanceID: 123, index: 0)'",
      "Prefer using instanceID (more reliable); name resolution may fail on newly created objects or during scene loading"
    ]
  }
